{
  "agent_id": "leave_approval_v1",
  "display_name": "Leave Approval Agent",
  "version": "1.0.0",
  "description": "Leave application and approval workflow",
  "trigger": {
    "type": "user_query",
    "config": {}
  },
  "intent": {
    "action_id": "leave_approval_v1"
  },
  "policy": {
    "allowed_personas": [
      "student",
      "faculty",
      "staff"
    ],
    "required_data_scope": [
      "hr.own",
      "timetable.own",
      "org_hierarchy.read"
    ],
    "requires_confirmation": true,
    "human_approval_required": true,
    "approval_level": "org_hierarchy_configured"
  },
  "steps": [
    {
      "node_id": "validate_action",
      "type": "action",
      "config": {
        "action_id": "leave_approval_v1"
      },
      "output_key": "action_meta"
    },
    {
      "node_id": "fetch_scope",
      "type": "fetch",
      "config": {
        "action_id": "leave_approval_v1"
      },
      "output_key": "leave_data"
    },
    {
      "node_id": "approval_gate",
      "type": "approval",
      "config": {
        "action_id": "leave_approval_v1",
        "claim_set_key": "leave_data"
      },
      "output_key": "approval_result"
    }
  ],
  "edges": [
    {
      "from": "START",
      "to": "validate_action"
    },
    {
      "from": "validate_action",
      "to": "fetch_scope"
    },
    {
      "from": "fetch_scope",
      "to": "approval_gate"
    },
    {
      "from": "approval_gate",
      "to": "END_SUCCESS"
    }
  ],
  "config": {},
  "audit": {
    "log_fields": [
      "leave_type",
      "requested_days"
    ],
    "hash_fields": [],
    "retention_days": 365
  },
  "metadata": {
    "created_at": "2026-04-15",
    "created_by": "engineering",
    "tenant_overridable_fields": []
  }
}