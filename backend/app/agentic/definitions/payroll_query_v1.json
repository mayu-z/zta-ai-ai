{
  "agent_id": "payroll_query_v1",
  "display_name": "Payroll Query Agent",
  "version": "1.0.0",
  "description": "Scoped payroll read flow",
  "trigger": {
    "type": "user_query",
    "config": {}
  },
  "intent": {
    "action_id": "payroll_query_v1"
  },
  "policy": {
    "allowed_personas": [
      "faculty",
      "staff"
    ],
    "required_data_scope": [
      "payroll.own"
    ]
  },
  "steps": [
    {
      "node_id": "validate_action",
      "type": "action",
      "config": {
        "action_id": "payroll_query_v1"
      },
      "output_key": "action_meta"
    },
    {
      "node_id": "fetch_scope",
      "type": "fetch",
      "config": {
        "action_id": "payroll_query_v1"
      },
      "output_key": "payroll_data"
    },
    {
      "node_id": "approval_gate",
      "type": "approval",
      "config": {
        "action_id": "payroll_query_v1",
        "claim_set_key": "payroll_data"
      },
      "output_key": "approval_result"
    }
  ],
  "edges": [
    {
      "from": "START",
      "to": "validate_action"
    },
    {
      "from": "validate_action",
      "to": "fetch_scope"
    },
    {
      "from": "fetch_scope",
      "to": "approval_gate"
    },
    {
      "from": "approval_gate",
      "to": "END_SUCCESS"
    }
  ],
  "config": {
    "cache_results": false
  },
  "audit": {
    "log_fields": [
      "field_classifications"
    ],
    "hash_fields": [
      "salary",
      "net_pay"
    ],
    "retention_days": 365
  },
  "metadata": {
    "created_at": "2026-04-15",
    "created_by": "engineering",
    "tenant_overridable_fields": []
  }
}