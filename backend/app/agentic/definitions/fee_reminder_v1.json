{
  "agent_id": "fee_reminder_v1",
  "display_name": "Fee Reminder Agent",
  "version": "1.0.0",
  "description": "Scheduled fee reminder flow",
  "trigger": {
    "type": "scheduled",
    "config": {
      "cron": "0 9 * * *"
    }
  },
  "intent": {
    "action_id": "fee_reminder_v1"
  },
  "policy": {
    "allowed_personas": [
      "student",
      "staff"
    ],
    "required_data_scope": [
      "fees.own"
    ]
  },
  "steps": [
    {
      "node_id": "validate_action",
      "type": "action",
      "config": {
        "action_id": "fee_reminder_v1"
      },
      "output_key": "action_meta"
    },
    {
      "node_id": "fetch_fees",
      "type": "fetch",
      "config": {
        "action_id": "fee_reminder_v1"
      },
      "output_key": "fees_data"
    },
    {
      "node_id": "check_outstanding",
      "type": "condition",
      "config": {
        "expression": "{{fees_data.row_count}} > 0"
      }
    },
    {
      "node_id": "approval_gate",
      "type": "approval",
      "config": {
        "action_id": "fee_reminder_v1",
        "claim_set_key": "fees_data"
      },
      "output_key": "approval_result"
    }
  ],
  "edges": [
    {
      "from": "START",
      "to": "validate_action"
    },
    {
      "from": "validate_action",
      "to": "fetch_fees"
    },
    {
      "from": "fetch_fees",
      "to": "check_outstanding"
    },
    {
      "from": "check_outstanding",
      "to": "approval_gate",
      "condition": "true"
    },
    {
      "from": "check_outstanding",
      "to": "END_NO_FEES",
      "condition": "false"
    },
    {
      "from": "approval_gate",
      "to": "END_SUCCESS"
    }
  ],
  "config": {
    "rate_limit_key": "fee_reminder",
    "rate_limit_max_per_day": 1
  },
  "audit": {
    "log_fields": [
      "outstanding_balance",
      "due_date"
    ],
    "hash_fields": [],
    "retention_days": 365
  },
  "metadata": {
    "created_at": "2026-04-15",
    "created_by": "engineering",
    "tenant_overridable_fields": [
      "config.rate_limit_max_per_day"
    ]
  }
}