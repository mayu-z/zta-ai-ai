{
  "agent_id": "refund_request_v1",
  "display_name": "Refund Request Agent",
  "version": "1.0.0",
  "description": "Submit and route refund requests",
  "trigger": {
    "type": "user_query",
    "config": {}
  },
  "intent": {
    "action_id": "refund_request_v1"
  },
  "policy": {
    "allowed_personas": [
      "student",
      "staff",
      "faculty"
    ],
    "required_data_scope": [
      "fees.own",
      "refund_policy.read"
    ],
    "requires_confirmation": true,
    "human_approval_required": true,
    "approval_level": "finance_officer"
  },
  "steps": [
    {
      "node_id": "validate_action",
      "type": "action",
      "config": {
        "action_id": "refund_request_v1"
      },
      "output_key": "action_meta"
    },
    {
      "node_id": "fetch_scope",
      "type": "fetch",
      "config": {
        "action_id": "refund_request_v1"
      },
      "output_key": "refund_data"
    },
    {
      "node_id": "approval_gate",
      "type": "approval",
      "config": {
        "action_id": "refund_request_v1",
        "claim_set_key": "refund_data"
      },
      "output_key": "approval_result"
    }
  ],
  "edges": [
    {
      "from": "START",
      "to": "validate_action"
    },
    {
      "from": "validate_action",
      "to": "fetch_scope"
    },
    {
      "from": "fetch_scope",
      "to": "approval_gate"
    },
    {
      "from": "approval_gate",
      "to": "END_SUCCESS"
    }
  ],
  "config": {},
  "audit": {
    "log_fields": [
      "requested_amount"
    ],
    "hash_fields": [],
    "retention_days": 365
  },
  "metadata": {
    "created_at": "2026-04-15",
    "created_by": "engineering",
    "tenant_overridable_fields": []
  }
}