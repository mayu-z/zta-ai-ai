{
  "agent_id": "bulk_notification_v1",
  "display_name": "Bulk Notification Agent",
  "version": "1.0.0",
  "description": "Admin bulk notification execution",
  "trigger": {
    "type": "admin_initiated",
    "config": {}
  },
  "intent": {
    "action_id": "bulk_notification_v1"
  },
  "policy": {
    "allowed_personas": [
      "registrar",
      "dept_head",
      "admin",
      "finance_officer"
    ],
    "required_data_scope": [
      "user_directory.department_scope"
    ],
    "requires_confirmation": true
  },
  "steps": [
    {
      "node_id": "validate_action",
      "type": "action",
      "config": {
        "action_id": "bulk_notification_v1"
      },
      "output_key": "action_meta"
    },
    {
      "node_id": "fetch_scope",
      "type": "fetch",
      "config": {
        "action_id": "bulk_notification_v1"
      },
      "output_key": "audience_data"
    },
    {
      "node_id": "approval_gate",
      "type": "approval",
      "config": {
        "action_id": "bulk_notification_v1",
        "claim_set_key": "audience_data"
      },
      "output_key": "approval_result"
    }
  ],
  "edges": [
    {
      "from": "START",
      "to": "validate_action"
    },
    {
      "from": "validate_action",
      "to": "fetch_scope"
    },
    {
      "from": "fetch_scope",
      "to": "approval_gate"
    },
    {
      "from": "approval_gate",
      "to": "END_SUCCESS"
    }
  ],
  "config": {},
  "audit": {
    "log_fields": [
      "recipient_count"
    ],
    "hash_fields": [
      "message"
    ],
    "retention_days": 365
  },
  "metadata": {
    "created_at": "2026-04-15",
    "created_by": "engineering",
    "tenant_overridable_fields": []
  }
}