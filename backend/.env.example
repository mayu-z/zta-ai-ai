# =============================================================================
# ZTA-AI Backend - Environment Variables
# Copy this file to .env and fill in the values before running.
# =============================================================================

# Application
APP_NAME=ZTA-AI
ENVIRONMENT=development   # development | production

# Database (required)
DATABASE_URL=postgresql+psycopg2://zta:zta@localhost:5432/zta_ai

# Redis (required)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Secret store backend (env | file | vault | aws_secrets_manager)
SECRETS_BACKEND=env
SECRETS_CACHE_TTL_SECONDS=300

# File secret backend
SECRETS_FILE_PATH=

# Vault secret backend
VAULT_ADDR=
VAULT_TOKEN=
VAULT_TOKEN_ENV_VAR=VAULT_TOKEN
VAULT_KV_MOUNT=secret
VAULT_SECRET_PATH_PREFIX=zta-ai/

# AWS Secrets Manager backend
AWS_SECRETS_MANAGER_REGION=
AWS_SECRETS_MANAGER_PREFIX=

# Security (CHANGE THESE IN PRODUCTION)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=30
JWT_REFRESH_WINDOW_MINUTES=5

# CORS (comma-separated list of allowed frontend origins)
ALLOWED_ORIGINS=["http://localhost:8080","http://localhost:3000"]

# Auth
AUTH_PROVIDER=mock_google        # mock_google | oidc | saml
USE_MOCK_GOOGLE_OAUTH=true
MOCK_GOOGLE_TOKEN_PREFIX=mock:
DEV_AUTO_PROVISION_IDENTITY=true
DEV_AUTO_CREATE_TENANT_ON_LOGIN=false
DEV_DEFAULT_PERSONA=executive    # executive | it_head | faculty | student | dept_head | admin_staff
ENABLE_SYSTEM_ADMIN_MOCK_LOGIN=true
SYSTEM_ADMIN_MOCK_TOKEN_PREFIX=mock_admin:
SYSTEM_ADMIN_ALLOWED_EMAILS=sysadmin@zta.local

# OIDC (required when AUTH_PROVIDER=oidc in production)
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_SHARED_SECRET=
OIDC_ALLOWED_ALGORITHMS=RS256,HS256

# SAML (required when AUTH_PROVIDER=saml in production)
SAML_IDP_METADATA_URL=
SAML_SP_ENTITY_ID=

# MFA (TOTP)
MFA_TOTP_ISSUER=ZTA-AI
MFA_TOTP_PERIOD_SECONDS=30
MFA_TOTP_WINDOW_STEPS=1

# SLM (required for real SLM mode; leave blank to disable SLM)
SLM_PROVIDER=openai
SLM_BASE_URL=https://api.openai.com/v1
SLM_API_KEY=                     # Single key (deprecated, use SLM_API_KEYS instead)
SLM_API_KEYS=                    # Comma-separated API keys for adaptive load balancing
SLM_REQUESTS_PER_MINUTE=50
SLM_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_API_KEYS=
SLM_TEMPERATURE=0.45
SLM_TOP_P=0.9
SLM_MAX_TOKENS=512
SLM_ZERO_LEARNING_ENFORCED=true
SLM_ZERO_LEARNING_HEADER_NAME=X-ZTA-Zero-Learning
SLM_ZERO_LEARNING_HEADER_VALUE=true
SLM_ZERO_LEARNING_AUDIT_LOG_ENABLED=true

# Egress controls (required in production)
EGRESS_ALLOWED_HOSTS=localhost,api.openai.com

# Service-to-service mTLS (required in production)
# Generate with: ./scripts/generate_mtls_artifacts.sh --out-dir ./certs/mtls/current --force
SERVICE_MTLS_ENABLED=false
SERVICE_MTLS_CLIENT_CERT_PATH=
SERVICE_MTLS_CLIENT_KEY_PATH=
SERVICE_MTLS_CA_BUNDLE_PATH=

# Limits
DAILY_QUERY_LIMIT=50
INTENT_CACHE_TTL_SECONDS=3600

